<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="500.0" stylesheets="@../../../../application/application.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ilacsistemi.controller.GirisController">
   <children>
      <VBox alignment="CENTER" layoutX="100.0" layoutY="50.0" prefHeight="300.0" prefWidth="300.0" spacing="15.0" styleClass="card" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0" AnchorPane.topAnchor="50.0">
         <children>
            <Label styleClass="header-label" text="Eczane İlaç Sistemi" textFill="#2c3e50">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <Label fx:id="lblMesaj" textFill="RED" />
            <TextField fx:id="txtEmail" promptText="E-Posta Adresiniz" />
            <PasswordField fx:id="txtSifre" promptText="Şifreniz" />
            <Button mnemonicParsing="false" onAction="#girisYap" prefWidth="200.0" styleClass="action-button" text="Giriş Yap" />
            <Hyperlink onAction="#kayitEkraniAc" text="Hesabın yok mu? Kayıt Ol" />
            <Hyperlink onAction="#sifremiUnuttumAc" text="Şifremi Unuttum" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
