<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="500.0" stylesheets="@../../../../application/application.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ilacsistemi.controller.KayitController">
   <children>
      <VBox alignment="CENTER" layoutX="100.0" layoutY="30.0" prefHeight="440.0" prefWidth="300.0" spacing="15.0" styleClass="card" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0" AnchorPane.topAnchor="30.0">
         <children>
            <Label styleClass="header-label" text="Sisteme Kayıt Ol" textFill="#2c3e50">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>
            <Label fx:id="lblMesaj" textFill="RED" />
            <TextField fx:id="txtAd" promptText="Adınız" />
            <TextField fx:id="txtSoyad" promptText="Soyadınız" />
            <TextField fx:id="txtEmail" promptText="E-Posta Adresiniz" />
            <PasswordField fx:id="txtSifre" promptText="Şifreniz" />
            <ComboBox fx:id="cmbRol" prefWidth="300.0" promptText="Rol Seçiniz" />
            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#geriDon" styleClass="button" text="Geri Dön" />
                  <Button mnemonicParsing="false" onAction="#kayitOl" styleClass="action-button" text="Kayıt Ol" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
