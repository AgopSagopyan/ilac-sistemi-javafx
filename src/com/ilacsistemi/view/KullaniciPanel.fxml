<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@../../../../application/application.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ilacsistemi.controller.KullaniciController">
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Label styleClass="header-label" text="Kullanıcı Paneli - İlaç Sorgulama">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                     <children>
                        <Button mnemonicParsing="false" onAction="#cikisYap" styleClass="danger-button" text="Çıkış Yap" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            
            <HBox spacing="15.0" styleClass="card">
               <children>
                  <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="sub-header-label" text="Aranacak İlaç Adı:" />
                        <TextField fx:id="txtIlacArama" promptText="Örn: Parol" />
                     </children>
                  </VBox>
                  <VBox spacing="10.0">
                     <children>
                        <Label styleClass="sub-header-label" text="Mevcut Konumunuz (X, Y):" />
                        <HBox spacing="5.0">
                           <children>
                              <TextField fx:id="txtEnlem" prefWidth="70.0" promptText="Enlem" text="41.0" />
                              <TextField fx:id="txtBoylam" prefWidth="70.0" promptText="Boylam" text="29.0" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <VBox alignment="BOTTOM_CENTER">
                     <children>
                        <Button mnemonicParsing="false" onAction="#ilacAra" prefHeight="35.0" styleClass="action-button" text="Sorgula" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <Label fx:id="lblDurum" textFill="#2c3e50" />
            
            <HBox spacing="15.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="sub-header-label" text="Eczane Stok Durumu (En Yakından Uzağa)" />
                        <TableView fx:id="tblEczaneler" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colEczaneAdi" prefWidth="150.0" text="Eczane Adı" />
                            <TableColumn fx:id="colMiktar" prefWidth="75.0" text="Stok" />
                            <TableColumn fx:id="colMesafe" prefWidth="100.0" text="Mesafe (Birim)" />
                          </columns>
                        </TableView>
                     </children>
                  </VBox>
                  
                  <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="sub-header-label" text="Muadil (Benzer Tür) İlaç Önerileri" />
                        <TableView fx:id="tblMuadiller" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colMuadilIlac" prefWidth="150.0" text="İlaç Adı" />
                            <TableColumn fx:id="colMuadilTur" prefWidth="150.0" text="Tür" />
                          </columns>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
