<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.TitledPane?>

<BorderPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.DashboardController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <top>
        <HBox spacing="15.0" alignment="CENTER_LEFT" BorderPane.alignment="CENTER">
            <padding><Insets bottom="10.0" /></padding>
            <Label fx:id="welcomeLbl" styleClass="label-header" />
            <Button text="Çıkış Yap" onAction="#handleLogout" />
        </HBox>
    </top>
    <center>
        <TableView fx:id="tableView" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="idCol" text="ID" />
                <TableColumn fx:id="medCol" prefWidth="150.0" text="İlaç Adı" />
                <TableColumn fx:id="qtyCol" text="Stok Adedi" />
                <TableColumn fx:id="statusCol" text="Durum" />
            </columns>
        </TableView>
    </center>
    <bottom>
        <VBox spacing="15.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10.0" />
            </padding>
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label text="Seçili İlacın Stok Miktarını Güncelle: " />
                <TextField fx:id="qtyField" promptText="Yeni Miktar" />
                <Button text="Güncelle" onAction="#handleUpdate" />
                <Button text="Durumu Değiştir (Aktif/Pasif)" onAction="#handleToggleStatus" style="-fx-background-color: #FF9800; -fx-text-fill: white;" />
            </HBox>
            
            <TitledPane text="Yeni İlaç Ekle" collapsible="false">
                <GridPane hgap="10.0" vgap="10.0">
                    <padding><Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/></padding>
                    <Label text="İlaç Adı:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="newIlacAd" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    
                    <Label text="Etken Madde:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <TextField fx:id="newIlacEtken" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                    
                    <Label text="Açıklama:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="newIlacAciklama" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.columnSpan="3"/>
                    
                    <Label text="Stok Adedi:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="newIlacAdet" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    
                    <Button text="Ekle" onAction="#handleAddMedicine" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                </GridPane>
            </TitledPane>
        </VBox>
    </bottom>
</BorderPane>
