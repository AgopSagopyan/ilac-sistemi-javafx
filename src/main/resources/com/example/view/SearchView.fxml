<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.Pane?>

<BorderPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.SearchController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
            <padding><Insets bottom="10.0" /></padding>
            <Button text="Geri" onAction="#handleBack" />
            <TextField fx:id="searchField" prefWidth="250.0" promptText="İlaç Adı Girin..." />
            <Button text="Ara" onAction="#handleSearch" />
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.6">
            <TableView fx:id="tableView">
                <columns>
                    <TableColumn fx:id="pharmacyCol" prefWidth="150.0" text="Eczane Adı" />
                    <TableColumn fx:id="medicineCol" prefWidth="120.0" text="İlaç Adı" />
                    <TableColumn fx:id="distanceCol" prefWidth="100.0" text="Mesafe" />
                    <TableColumn fx:id="stockCol" prefWidth="100.0" text="Stok" />
                </columns>
            </TableView>
            <Pane fx:id="mapPane" styleClass="map-pane" minWidth="200.0" />
        </SplitPane>
    </center>
    <bottom>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10.0" />
            </padding>
            <Button fx:id="equivalentBtn" disable="true" text="Eşdeğer İlaçları Göster" onAction="#showEquivalents" />
            <ListView fx:id="equivalentListView" prefHeight="100.0" />
        </VBox>
    </bottom>
</BorderPane>
